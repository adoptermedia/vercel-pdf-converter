{
  "rewrites": [
    { "source": "/vpdf", "destination": "/vpdf/index.html" },
    { "source": "/vpdf/(.*)", "destination": "/vpdf/$1" },
    { "source": "/(.*)", "destination": "/api" }
  ],
  "build": {
    "env": {
      "PUPPETEER_PRODUCT": "firefox",
      "PUPPETEER_EXECUTABLE_PATH": "/usr/bin/firefox"
    }
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
